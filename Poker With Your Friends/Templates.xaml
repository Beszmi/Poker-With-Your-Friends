<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Poker_With_Your_Friends"
    xmlns:Model="using:Poker_With_Your_Friends.Model"
    x:Class="Poker_With_Your_Friends.Templates">

    <DataTemplate x:Key="CardTemplate" x:DataType="Model:Card">
        <Canvas Width="100" Height="140">
            <TextBlock Text="{x:Bind GetValueSymbol()}" FontSize="10" Canvas.Left="10" Canvas.Top="10"/>
            <TextBlock Text="{x:Bind GetSuitSymbol()}" FontSize="10" Canvas.Left="10" Canvas.Top="20"/>
        </Canvas>
    </DataTemplate>
    
</ResourceDictionary>
