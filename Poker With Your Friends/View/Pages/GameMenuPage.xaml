<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Poker_With_Your_Friends.GameMenuPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Poker_With_Your_Friends"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:Model="using:Poker_With_Your_Friends.Model"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <!--
        Title
    -->
        <TextBlock Text="Game Window" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="24"/>

        <TextBlock Grid.Column="0" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="24" FontWeight="Bold">
        <Run Text="Hi, "/>
        <Run Text="{x:Bind viewModel.client.PlayerStore.CurrentPlayer.Name, Mode=OneWay}"/>
        </TextBlock>

        <StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,20,0,0" Spacing="5" Canvas.ZIndex="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,20,0,0" Spacing="5">
                <TextBlock Text="Your tables name:" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBox Width="200" Text="{x:Bind viewModel.NewTableName, Mode=TwoWay}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </StackPanel>
            <Button VerticalAlignment="Center" HorizontalAlignment="Right" Content="Create new table" Click="NewGameButton_Click" IsEnabled="{x:Bind viewModel.isNewTableButtonEnabled, Mode=OneWay}"/>
        </StackPanel>

        <!--
        Tables grid
    -->
        <GridView Grid.Row="1" ItemsSource="{x:Bind viewModel.Tables, Mode=TwoWay}" ItemClick="Table_ItemClick" IsItemClickEnabled="True" VerticalAlignment="Center" HorizontalAlignment="Center">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="Model:Table">
                    <Grid Background="LightGreen" Height="200" Width="200">
                        <FontIcon Glyph="&#xE76E;" />
                        <TextBlock Text="{x:Bind Name, Mode=OneWay}" VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="24" Foreground="Red"/>
                        <TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Left" FontSize="12">
                        <Run Text="Players: "/>
                        <Run Text="{x:Bind Players.Count, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Right" FontSize="12">
                        <Run Text="Pot: "/>
                        <Run Text="{x:Bind Pot, Mode=OneWay}"/>
                        <LineBreak/>
                        <Run Text="Round: "/>
                        <Run Text="{x:Bind Round, Mode=OneWay}"/>
                        <LineBreak/>
                        <Run Text="Small blind: "/>
                        <Run Text="{x:Bind SmallBlind, Mode=OneWay}"/>
                        <Run Text="$"/>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
