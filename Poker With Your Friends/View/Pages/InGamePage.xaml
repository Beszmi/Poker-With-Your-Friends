<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Poker_With_Your_Friends.InGamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Poker_With_Your_Friends"
    xmlns:Model="using:Poker_With_Your_Friends.Model"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///View/Templates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0" Grid.Row="0" Content="❌ leave Table" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Click="LeaveTableButton_Click" IsEnabled="{x:Bind viewModel.LeaveTableButtonEnabled, Mode=OneWay}"/>

        <TextBlock Grid.Column="0" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10">
            <Run Text="Players count: "/>
            <Run Text="{x:Bind viewModel.Table.Players.Count, Mode=OneWay}"/>
            <Run Text=" Players: "/>
        </TextBlock>

        <TextBlock Grid.Column="0" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="24" Text="{x:Bind viewModel.Table.TableText, Mode=OneWay}"/>

        <ListView Grid.Column="0" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" ItemsSource="{x:Bind viewModel.Table.Housecards, Mode=OneWay}" Margin="10">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="Model:Card">
                    <ContentControl Content="{x:Bind}" ContentTemplate="{StaticResource CardTemplate}"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="3" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10">
            <Run Text="Pot: "/>
            <Run Text="{x:Bind viewModel.Table.Pot, Mode=OneWay}"/>
            <LineBreak/>
            <Run Text="Round: "/>
            <Run Text="{x:Bind viewModel.Table.Round, Mode=OneWay}"/>
            <LineBreak/>
            <Run Text="Small blind: "/>
            <Run Text="{x:Bind viewModel.Table.SmallBlind, Mode=OneWay}"/>
            <Run Text="$"/>
        </TextBlock>

        <StackPanel Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="3" HorizontalAlignment="Center" VerticalAlignment="Bottom" Visibility="{x:Bind viewModel.IsplayerOnOwnTable, Mode=OneWay}">
            <ListView ItemsSource="{x:Bind viewModel.MyCards, Mode=OneWay}">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="Model:Card">
                        <ContentControl Content="{x:Bind}" ContentTemplate="{StaticResource CardTemplate}"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <StackPanel Orientation="Horizontal">
                <Button Content="Call" IsEnabled="{x:Bind viewModel.PlayerActionButtonsEnabled, Mode=OneWay}" Click="viewModel.CallButton_Click"/>
                <Button Content="Raise" IsEnabled="{x:Bind viewModel.PlayerActionButtonsEnabled, Mode=OneWay}" Click="viewModel.RaiseButton_Click"/>
                <Button Content="Fold" IsEnabled="{x:Bind viewModel.PlayerActionButtonsEnabled, Mode=OneWay}" Click="viewModel.FoldButton_Click"/>
            </StackPanel>
        </StackPanel>

        <ListView Grid.Column="1" Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Bottom" ItemsSource="{x:Bind viewModel.Table.Players, Mode=OneWay}" Margin="10">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="Model:Player">
                    <Grid Background="LightGreen" Height="50" Width="200">
                        <TextBlock Text="{x:Bind Name}" VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="24" Foreground="Red"/>
                        <TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Left" FontSize="12">
                    <Run Text="Chips: "/>
                    <Run Text="{x:Bind Chips}"/>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button Grid.Column="0" Grid.Row="4" Content="➕Join Game" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10" Click="JoinGameButton_Click" Visibility="{x:Bind viewModel.IsJoinButtonVisible, Mode=OneWay}"/>
        <Button Grid.Column="0" Grid.Row="4" Content="➖Leave Game" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10" Click="LeaveGameButton_Click" Visibility="{x:Bind viewModel.IsLeaveButtonVisible, Mode=OneWay}"/>

        <StackPanel Grid.Column="2" Grid.Row="4" Orientation="Vertical">
            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center">
                <Run Text="Time left: "/>
                <Run Text="{x:Bind viewModel.TimerRemainingText, Mode=OneWay}"/>
                <Run Text=" Seconds"/>
            </TextBlock>
            <ProgressBar Minimum="0" Maximum="{x:Bind viewModel.TimerProgressMaximum, Mode=OneWay}" Width="300" Value="{x:Bind viewModel.TimerProgressValue, Mode=OneWay}" />
        </StackPanel>
    </Grid>
</Page>
