<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Poker_With_Your_Friends.InGamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Poker_With_Your_Friends"
    xmlns:Model="using:Poker_With_Your_Friends.Model"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///View/Templates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Column="0" Grid.Row="0" Content="❌ leave Table" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Click="LeaveTableButton_Click"/>

        <TextBlock Grid.Column="0" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10">
            <Run Text="Players count: "/>
            <Run Text="{x:Bind viewModel.Table.Players.Count, Mode=OneWay}"/>
            <Run Text=" Players: "/>
        </TextBlock>

        <TextBlock Grid.Column="0" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="24" Text="{x:Bind viewModel.TableText}"/>

         <ListView Grid.Column="0" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" ItemsSource="{x:Bind viewModel.Table.Housecards}">
             <ListView.ItemsPanel>
                 <ItemsPanelTemplate>
                     <ItemsStackPanel Orientation="Horizontal" />
                 </ItemsPanelTemplate>
             </ListView.ItemsPanel>
             <ListView.ItemTemplate>
                 <DataTemplate x:DataType="Model:Card">
                     <ContentControl Content="{x:Bind}" ContentTemplate="{StaticResource CardTemplate}"/>
                 </DataTemplate>
             </ListView.ItemTemplate>
         </ListView>

         <ListView Grid.Column="0" Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center" ItemsSource="{x:Bind viewModel.Table.Players}">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="Model:Player">
                    <Grid Background="LightGreen" Height="50" Width="200">
                        <TextBlock Text="{x:Bind Name, Mode=OneWay}" VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="24" Foreground="Red"/>
                        <TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Left" FontSize="12">
                            <Run Text="Chips: "/>
                            <Run Text="{x:Bind Chips, Mode=OneWay}"/>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Column="0" Grid.Row="3" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10">
            <Run Text="Pot: "/>
            <Run Text="{x:Bind viewModel.Table.Pot, Mode=OneWay}"/>
            <LineBreak/>
            <Run Text="Round: "/>
            <Run Text="{x:Bind viewModel.Table.Round, Mode=OneWay}"/>
            <LineBreak/>
            <Run Text="Small blind: "/>
            <Run Text="{x:Bind viewModel.Table.SmallBlind, Mode=OneWay}"/>
            <Run Text="$"/>
        </TextBlock>

        <StackPanel Grid.Column="0" Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <ListView ItemsSource="{x:Bind Model:Client.CurrentPlayer.Cards}">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="Model:Card">
                        <ContentControl Content="{x:Bind}" ContentTemplate="{StaticResource CardTemplate}"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <StackPanel Orientation="Horizontal">
                <Button Content="Call" IsEnabled="{x:Bind viewModel.PlayerActionButtonsEnabled, Mode=OneWay}" Click="viewModel.CallButton_Click"/>
                <Button Content="Raise" IsEnabled="{x:Bind viewModel.PlayerActionButtonsEnabled, Mode=OneWay}" Click="viewModel.RaiseButton_Click"/>
                <Button Content="Fold" IsEnabled="{x:Bind viewModel.PlayerActionButtonsEnabled, Mode=OneWay}" Click="viewModel.FoldButton_Click"/>
            </StackPanel>
        </StackPanel>

        <Button Grid.Column="0" Grid.Row="3" Content="➕Join Game" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10" Click="JoinGameButton_Click" Visibility="{x:Bind viewModel.isJoinButtonVisible, Mode=OneWay}"/>
        <Button Grid.Column="0" Grid.Row="3" Content="➖Leave Game" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10" Click="LeaveGameButton_Click" Visibility="{x:Bind viewModel.isLeaveButtonVisible, Mode=OneWay}"/>
    </Grid>
</Page>
