<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Poker_With_Your_Friends"
    xmlns:Model="using:Poker_With_Your_Friends.Model">

    <DataTemplate x:Key="CardTemplate">
        <Canvas Width="100" Height="140">
            <Border Width="100" Height="140" BorderBrush="Black" BorderThickness="2" CornerRadius="10" Background="White">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
            </Border>
            <TextBlock Text="{Binding ValueSymbol}" Foreground="{Binding Color}" FontSize="20" Canvas.Left="10" Canvas.Top="5"/>
            <TextBlock Text="{Binding SuitSymbol}" Foreground="{Binding Color}" FontSize="20" Canvas.Left="10" Canvas.Top="20"/>
        </Canvas>
    </DataTemplate>
    
</ResourceDictionary>
